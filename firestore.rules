rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /shops/{shopId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == shopId;
    }
    
    match /products/{productId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.shop_id;
      allow update: if request.auth != null && request.auth.uid == resource.data.shop_id;
      allow delete: if request.auth != null && (resource == null || request.auth.uid == resource.data.shop_id);
    }
    
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.shop_id;
    }
  }
}
